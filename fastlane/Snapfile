# Katafract screenshot pipeline — fastlane snapshot config

project("./DocArmor.xcodeproj")

devices([
  "iPhone 17 Pro Max",
  "iPad Pro 13-inch (M5)"
])

# Pin to the actual installed sim runtime version. cmfmbp has iOS 26.4 (23E244)
# AND 26.4.1 (23E254a). Fastlane snapshot's default picks the runtime *name* (26.4)
# but the iPhone 17 Pro Max + iPad Pro 13" M5 sims are built against 26.4.1, so
# `OS=26.4` fails to match. Pinning the patch version forces xcodebuild to pick
# the correct runtime. Update if/when runner upgrades past 26.4.1.
ios_version("26.4.1")

languages(["en-US"])

# UI test scheme name
scheme("DocArmorUITests")

output_directory("./fastlane/screenshots")
clear_previous_screenshots(true)
override_status_bar(true)
override_status_bar_arguments("--time 9:41 --batteryState charged --batteryLevel 100")

launch_arguments([
  "--screenshots --skip-onboarding",
])

skip_open_summary(true)
concurrent_simulators(true)
