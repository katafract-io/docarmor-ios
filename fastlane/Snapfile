# Katafract screenshot pipeline — fastlane snapshot config

project("./DocArmor.xcodeproj")

devices([
  "iPhone 17 Pro Max",
  "iPad Pro 13-inch (M5)"
])

# Don't pin ios_version — runner has both iOS 26.4 (23E244) and 26.4.1 (23E254a)
# installed and iPhone 17 Pro Max sim is built for 26.4.1, so OS=26.4 doesn't match.
# Letting fastlane pick the latest installed runtime is more robust.
# ios_version("26.4")

languages(["en-US"])

# UI test scheme name
scheme("DocArmorUITests")

output_directory("./fastlane/screenshots")
clear_previous_screenshots(true)
override_status_bar(true)
override_status_bar_arguments("--time 9:41 --batteryState charged --batteryLevel 100")

launch_arguments([
  "--screenshots --skip-onboarding",
])

skip_open_summary(true)
concurrent_simulators(true)
